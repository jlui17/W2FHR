{
  "name": "w2_fhr",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "bin": {
    "w2_fhr": "bin/w2_fhr.js"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm build:frontend && pnpm build:backend && pnpm build:cdk",
    "build:cdk": "tsc",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "cd src/GoogleSheets && go mod tidy && go mod vendor && go test ./...",
    "test": "pnpm run test:backend",
    "test:backend": "cd src/GoogleSheets && go test ./...",
    "cdk": "cdk",
    "deploy": "pnpm build && pnpm cdk deploy --all",
    "deploy:auth": "pnpm run build:cdk && pnpm cdk deploy AuthService",
    "deploy:api": "pnpm build:backend && pnpm run build:cdk && pnpm cdk deploy ApiService",
    "deploy:frontend": "pnpm build:frontend && pnpm run build:cdk && pnpm cdk deploy FrontendService",
    "watch": "tsc -w"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "yarn"],
    "ignoredBuiltDependencies": [
      "esbuild",
      "yarn"
    ],
    "overrides": {
      "handlebars": ">=4.7.9",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=2.0.3",
      "yaml": ">=2.8.3",
      "fast-xml-parser": ">=4.5.5",
      "minimatch": ">=9.0.7",
      "@remix-run/router": ">=1.23.2",
      "@smithy/config-resolver": ">=4.4.0",
      "glob": ">=10.5.0",
      "@babel/runtime": ">=7.26.10",
      "object-path": ">=0.11.8",
      "react-hook-form": "7.52.1"
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.13",
    "aws-cdk": "^2.1108.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-cdk/aws-lambda-go-alpha": "2.148.0-alpha.0",
    "aws-cdk-lib": "^2.241.0",
    "constructs": "^10.5.1",
    "source-map-support": "^0.5.21"
  }
}
